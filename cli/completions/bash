_registry_completions() {
    local cur prev cmd
    local cword

    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    cword=$COMP_CWORD

    local reg_cmd="${COMP_WORDS[0]}"

    cmd=""

    if [ "$cword" -eq 1 ]; then
        COMPREPLY=($(compgen -W "get set reset apply discard view-changes diff validate validate-config list search info detect backup export import help" -- "$cur"))
        return
    fi

    if [ "$cword" -ge 2 ]; then
        cmd="${COMP_WORDS[1]}"
    fi

    if [ "$cmd" != "get" ] && [ "$cmd" != "set" ]; then
        return
    fi

    # Build the full path from all arguments
    local full_path=""
    if [ "$cword" -ge 2 ]; then
        # Include all previous path components (from index 2 onwards)
        local i
        for ((i=2; i<COMP_CWORD; i++)); do
            full_path="${full_path}${COMP_WORDS[i]}"
        done
        # Add current word
        full_path="${full_path}${cur}"
    fi

    # Extract filter (part after last /) and base path
    local filter=""
    local base_path=""
    if [[ "$full_path" == */* ]]; then
        # Has at least one /, split into base and filter
        base_path="${full_path%/*}/"
        filter="${full_path##*/}"
    else
        # No /, treat entire thing as filter with empty base
        base_path=""
        filter="$full_path"
    fi

    # Build command args
    local cmd_args=("--complete" "--comp-cur" "$filter" "$cmd")
    if [ -n "$base_path" ]; then
        cmd_args+=("$base_path")
    fi

    local completions
    completions=$("$reg_cmd" "${cmd_args[@]}" 2>/dev/null)

    if [ -n "$completions" ]; then
        # Count slashes to determine if we're completing directories
        local slash_count
        slash_count=$(echo "$base_path" | tr -cd '/' | wc -c)

        # At category level (0 slashes) or package level (1 slash), add trailing /
        local need_trailing_slash=0
        if [ "$slash_count" -le 1 ]; then
            need_trailing_slash=1
            compopt -o nospace 2>/dev/null
        fi

        # Prepend base_path to completions and add trailing / for directories
        local -a full_completions=()
        for completion in $completions; do
            local full_completion="${base_path}${completion}"
            if [ "$need_trailing_slash" -eq 1 ] && [[ "$completion" != */ ]]; then
                full_completion="${full_completion}/"
            fi
            full_completions+=("$full_completion")
        done

        COMPREPLY=($(compgen -W "${full_completions[*]}" -- "$full_path"))
    fi
}

complete -F _registry_completions registry

if [ -f /usr/local/bin/registry ]; then
    complete -F _registry_completions /usr/local/bin/registry
fi

if [ -f /usr/local/sbin/registry ]; then
    complete -F _registry_completions /usr/local/sbin/registry
fi
